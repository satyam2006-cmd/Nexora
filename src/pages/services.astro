---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/ui/Card.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";

import c1 from "../assets/pics/card-pic1.png";
import c2 from "../assets/pics/card-pic2.png";
import c3 from "../assets/pics/card-pic3.png";
import c4 from "../assets/pics/card-pic4.png";
import c5 from "../assets/pics/card-pic5.png";
import c6 from "../assets/pics/card-pic6.png";

const services = [
  {
    index: 1,
    titleTop: "Search Engine",
    titleBottom: "Optimization",
    img: c1,
    alt: "SEO",
    description: "We shape search-friendly pages, keyword clusters, and technical improvements that make brands easier to discover and easier to trust.",
    benefits: ["Increased organic traffic", "Higher website rankings", "Better user experience", "Increased brand visibility"],
    cta: "Get SEO Audit",
  },
  {
    index: 2,
    titleTop: "Pay-per-click",
    titleBottom: "advertising",
    img: c2,
    alt: "PPC",
    description: "We plan focused ad campaigns with sharp messaging, conversion goals, and reporting that keeps spend connected to business outcomes.",
    benefits: ["Immediate website traffic", "Highly targeted advertising", "Measurable ROI", "Flexible budgeting options"],
    cta: "Start PPC Campaign",
  },
  {
    index: 3,
    titleTop: "Social Media",
    titleBottom: "Marketing",
    img: c3,
    alt: "Social Media Marketing",
    description: "We create content systems for Instagram, LinkedIn, and short-form channels so brands can show up consistently and meaningfully.",
    benefits: ["Increased brand awareness", "Better customer engagement", "Higher conversion rates", "Audience insights"],
    cta: "Social Media Strategy",
  },
  {
    index: 1,
    titleTop: "Email",
    titleBottom: "Marketing",
    img: c4,
    alt: "Email Marketing",
    description: "We design practical email journeys for announcements, lead nurturing, and follow-up sequences that keep customers moving.",
    benefits: ["Direct customer communication", "High ROI", "Personalized messaging", "Automated workflows"],
    cta: "Start Email Campaign",
  },
  {
    index: 2,
    titleTop: "Content",
    titleBottom: "Creation",
    img: c5,
    alt: "Content Creation",
    description: "We build content ideas, captions, landing-page copy, and campaign assets that make the brand sound clear, useful, and memorable.",
    benefits: ["Increased audience engagement", "Improved brand authority", "Better search visibility", "Valuable marketing assets"],
    cta: "Content Strategy",
  },
  {
    index: 3,
    titleTop: "Analytics and",
    titleBottom: "Tracking",
    img: c6,
    alt: "Analytics",
    description: "We turn campaign activity into simple dashboards, weekly insights, and next-step recommendations that make growth measurable.",
    benefits: ["Data-driven decision making", "Performance tracking", "User behavior insights", "ROI measurement"],
    cta: "Analytics Setup",
  },
];
---

<MainLayout 
  title="Services | Nexora Digitals" 
  description="Explore Nexora Digitals services by Satyam Bhagat, including SEO, PPC, social media marketing, email marketing, content creation, and analytics."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">
    <div class="text-center mb-16">
      <h1 class="mb-4 text-5xl font-medium leading-none tracking-tight md:text-6xl">Our Services</h1>
      <p class="text-xl font-normal leading-7 mx-auto max-w-3xl">
        Nexora Digitals presents a complete digital growth toolkit for brands that want stronger visibility, cleaner content, and measurable marketing systems.
      </p>
    </div>
    
    <div class="space-y-24">
      {services.map((service) => (
        <div class="service-item">
          <div class="mb-12">
            <ServiceCard
              index={service.index}
              titleTop={service.titleTop}
              titleBottom={service.titleBottom}
              img={service.img}
              alt={service.alt}
              description={service.description}
              benefits={service.benefits}
              cta={service.cta}
            />
          </div>
          
          <div class="grid md:grid-cols-2 gap-10 px-4">
            <div>
              <h3 class="text-2xl font-medium mb-4">What we offer</h3>
              <p class="mb-6">{service.description}</p>
              <a href={`mailto:digitalsnexora0@gmail.com?subject=Nexora%20${encodeURIComponent(service.cta)}`} class="inline-flex items-center px-8 py-4 bg-green text-dark rounded-2xl hover:bg-dark hover:text-white transition-all font-medium hover:translate-x-1">
                {service.cta}
                <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
            
            <div class="service-benefits-card bg-gray rounded-2xl p-8">
              <h3 class="text-2xl font-medium mb-4">Benefits</h3>
              <ul class="space-y-4">
                {service.benefits.map(benefit => (
                  <li class="flex items-start">
                    <svg class="mr-2 w-5 h-5 mt-1 text-green" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span>{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-24 text-center">
      <Card>
        <div class="p-10 md:p-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6">Ready to transform your digital presence?</h2>
          <p class="mb-10 text-xl max-w-2xl mx-auto">
            Contact Satyam Bhagat to discuss a clean, professional digital marketing presence for your business or internship portfolio.
          </p>
          <a href="mailto:digitalsnexora0@gmail.com?subject=Nexora%20Digital%20Consultation" class="inline-flex items-center px-10 py-5 bg-dark text-white rounded-2xl hover:bg-green hover:text-dark transition-all font-medium text-xl">
            Book a consultation
          </a>
        </div>
      </Card>
    </div>
  </div>
</MainLayout>

<style>
  .service-item:nth-child(even) {
    @apply py-16 -mx-4 px-4;
  }
  
  @media (min-width: 768px) {
    .service-item:nth-child(even) {
      @apply -mx-6 px-6;
    }
  }
</style>
