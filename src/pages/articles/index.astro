---
import MainLayout from "../../layouts/MainLayout.astro";
import ArticleCard from "../../components/ui/ArticleCard.astro";
import SearchForm from "../../components/ui/SearchForm.astro";
import { getCollection } from 'astro:content';
import type { CollectionEntry } from "astro:content";

const allBlogArticles: CollectionEntry<'blog'>[] = (await getCollection('blog'))
  .sort((a:CollectionEntry<'blog'>, b:CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<MainLayout title="Nexora Digitals - Insights">
	<main class="space-y-20">
            <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-3">
                <div class="mx-auto max-w-screen-sm text-center lg:mb-16 mb-8">
                    <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold">Nexora Insights</h2>
                    <p class="font-light sm:text-xl">Demo articles and notes about branding, content, search, and digital growth strategy.</p>
                </div> 
                <br>
                <SearchForm />
                <br>
                <div class="grid gap-8 lg:grid-cols-2">
                    {allBlogArticles.map(article => (
                        <ArticleCard article={article} />
                    ))}
                </div>  
            </div>
	</main>
</MainLayout>
