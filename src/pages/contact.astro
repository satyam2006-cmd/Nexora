---
import ContactSection from "../components/sections/Contact.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact Nexora Digitals | Digital Growth Brief"
  description="Start a digital growth brief with Nexora Digitals for SEO, content, paid campaigns, social media strategy, and AI-assisted brand systems."
>
  <section class="px-5 pb-10 pt-8 lg:px-0">
    <div class="mx-auto max-w-[1280px] rounded-[28px] border border-black/10 bg-[#f7f4ef] px-5 py-10 sm:px-8 lg:px-10 lg:py-14">
      <p class="text-sm font-medium uppercase tracking-[0.18em] text-black/45">Contact / briefing room</p>
      <h1 class="mt-6 max-w-5xl text-5xl font-medium leading-[0.95] sm:text-7xl lg:text-8xl">
        A clearer first conversation for your next growth move.
      </h1>
      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <span class="rounded-full border border-black/10 bg-white px-4 py-3 text-sm text-black/65">Strategy before execution</span>
        <span class="rounded-full border border-black/10 bg-white px-4 py-3 text-sm text-black/65">Human-edited AI workflows</span>
        <span class="rounded-full border border-black/10 bg-white px-4 py-3 text-sm text-black/65">SEO, content, paid, social</span>
      </div>
    </div>
  </section>
  <ContactSection />
</MainLayout>
