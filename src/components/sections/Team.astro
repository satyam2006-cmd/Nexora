---
import SectionTitle from "../ui/SectionTitle.astro";
import TeamCard from "../ui/TeamCard.astro";
import Section from "./Section.astro";

const description =
  "Nexora Digitals is independently owned, managed, designed, and developed by Satyam Bhagat.";

const team = [
  {
    pic: "/picnew.jpeg",
    name: "Satyam Bhagat",
    role: "Owner, Manager, Designer & Developer",
    description:
      "Satyam handles the complete Nexora Digitals experience: strategy, website design, content planning, frontend development, branding, and presentation.",
  },
];
---

<Section id="about">
  <div class="mt-[140px]">
    <SectionTitle sectionTitle="Team" description={description} />
    <div class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-8 sm:gap-10 md:grid-cols-2 lg:max-w-4xl">
      {
        team.map((member, index) => (
          <TeamCard
            key={index}
            pic={member.pic}
            name={member.name}
            role={member.role}
            description={member.description}
          />
        ))
      }
    </div>
  </div>
</Section>
