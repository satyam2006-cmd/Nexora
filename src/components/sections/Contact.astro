---
import Section from "./Section.astro";
---

<Section id="contact">
  <div class="relative mb-24 overflow-hidden rounded-[28px] border border-black/10 bg-[#f7f4ef] px-5 py-8 text-black sm:px-8 lg:px-10 lg:py-12">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="mb-5 text-sm font-medium uppercase tracking-[0.18em] text-black/45">/ contact /</p>
        <h2 class="max-w-xl text-5xl font-medium leading-[0.98] sm:text-6xl">
          Let us talk about your next campaign.
        </h2>
        <p class="mt-6 max-w-md text-lg leading-8 text-black/60">
          Send a short note and Satyam will reply with the next best step.
        </p>
        <a class="mt-8 inline-flex break-all rounded-2xl bg-black px-5 py-4 text-white transition hover:bg-[#b9ff66] hover:text-black" href="mailto:satyambhagat200623@gmail.com?subject=Nexora%20Digital%20Consultation">
          satyambhagat200623@gmail.com
        </a>
      </div>

      <div class="rounded-[24px] bg-white p-4 text-black sm:p-6">
        <form class="grid gap-3" action="mailto:satyambhagat200623@gmail.com" method="post" enctype="text/plain">
          <div class="grid gap-3 sm:grid-cols-2">
            <label class="group rounded-2xl border border-black/10 bg-white px-4 py-3">
              <span class="block text-xs uppercase tracking-[0.16em] text-black/40">Name</span>
              <input class="mt-3 w-full bg-transparent text-base outline-none placeholder:text-black/30" type="text" name="name" placeholder="Your name" />
            </label>
            <label class="group rounded-2xl border border-black/10 bg-white px-4 py-3">
              <span class="block text-xs uppercase tracking-[0.16em] text-black/40">Email</span>
              <input class="mt-3 w-full bg-transparent text-base outline-none placeholder:text-black/30" type="email" name="email" placeholder="you@company.com" />
            </label>
          </div>

          <label class="rounded-2xl border border-black/10 bg-white px-4 py-3">
            <span class="block text-xs uppercase tracking-[0.16em] text-black/40">Message</span>
            <textarea class="mt-3 min-h-36 w-full resize-none bg-transparent text-base outline-none placeholder:text-black/30" name="message" placeholder="What do you want to grow or fix?"></textarea>
          </label>

          <button class="mt-1 rounded-2xl bg-black px-6 py-5 text-left text-lg font-medium text-white transition hover:bg-[#b9ff66] hover:text-black" type="submit">
            Send the brief to Satyam
          </button>
        </form>
      </div>
    </div>
  </div>
</Section>
