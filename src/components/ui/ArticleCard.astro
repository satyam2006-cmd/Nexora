---
import { formatDate } from "../../utils";
import type { CollectionEntry } from "astro:content";
import ArticleIcon from "../../components/Icons/ArticleIcon.astro";
import VideoIcon from "../../components/Icons/VideoIcon.astro";

const { article } = Astro.props;

interface Props {
  article: CollectionEntry<'blog'>;
}
---

<article class="article-list-card flex min-h-[280px] flex-col justify-between rounded-[45px] border border-black/15 bg-white p-7 shadow-[0_5px_0_#191a23] transition duration-300 hover:-translate-y-1 sm:p-8">
  <div>
    <div class="mb-7 flex items-start justify-between gap-4 text-sm">
      <span class="inline-flex items-center rounded bg-green px-2.5 py-1 text-xs font-medium text-black">
        {article.data.type == 'Article' ? (<ArticleIcon />) : (<VideoIcon />)}
        {article.data.type}
      </span>
      <span class="font-medium">{formatDate(article.data.pubDate)}</span>
    </div>
    <h2 class="mb-4 text-2xl font-bold leading-tight tracking-tight">{article.data.title}</h2>
    <p class="text-lg leading-7" style="white-space: pre-line">{article.data.summary}</p>
  </div>
  <div class="mt-8 flex items-center justify-between gap-5">
    <div class="flex items-center space-x-4">
      <img class="h-8 w-8 rounded-full" src={article.data.authImage} alt={article.data.author + " avatar"} />
      <span class="font-bold">{article.data.author}</span>
    </div>
    <a href={'/articles/' + article.slug} class="inline-flex items-center gap-3 font-bold transition hover:text-green">
      Read more
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
      </a>
  </div>
</article>
