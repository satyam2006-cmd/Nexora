---
import ShortForm from "../ui/ShortForm.astro";

const links = [
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
  { name: "Blog", href: "/blog" },
  { name: "Team", href: "/#about" },
  { name: "Contact", href: "/contact" },
];
---

<section class="sm:px-5">
  <div class="w-full max-w-[1240px] mx-auto">
    <div
      class="px-[15px] bg-dark text-gray py-[55px] lg:px-[60px] sm:rounded-t-[45px]"
    >
      <div>
        <div
          class="flex flex-col lg:flex-row gap-7 items-center justify-between"
        >
          <picture>
            <a href="/">
              <span class="flex items-center gap-3">
                <img src="/favicon.png" alt="Nexora Digitals mark" class="h-10 w-10 rounded-full object-contain" />
                <span class="text-xl font-medium text-white">Nexora Digitals</span>
              </span>
            </a>
          </picture>
          <ul class="flex flex-col sm:flex-row gap-5">
            {
              links.map((link) => {
                return (
                  <li class="text-center">
                    <a class="underline" href={link.href}>
                      {link.name}
                    </a>
                  </li>
                );
              })
            }
          </ul>
          <a
            class="rounded-full border border-gray px-5 py-2 text-sm transition hover:bg-green hover:text-dark"
            href="https://github.com/satyam2006-cmd"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>
        </div>

        <div class="flex flex-col lg:flex-row mt-[66px] mb-[51px]">
          <div
            class="flex text-center lg:text-start flex-col w-full lg:w-[30%]"
          >
            <h3 class="mb-5 text-center md:text-left text-2xl text-green">Contact</h3>
            <div class="flex flex-col justify-between gap-4">
              <span> Email: digitalsnexora0@gmail.com </span>
              <span>
                Developer:
                <a class="underline" href="https://github.com/satyam2006-cmd" target="_blank" rel="noopener noreferrer">github.com/satyam2006-cmd</a>
              </span>
              <span class="lg:w-3/4">
                Owned and managed by Satyam Bhagat
              </span>
            </div>
          </div>
          <div class="flex-grow my-10 lg:my-0 lg:ml-12">
            <ShortForm />
          </div>
        </div>
      </div>

      <div class="h-[1px] bg-gray mb-5"></div>
      <div
        class="flex flex-col lg:flex-row h-20 justify-center mt-4 text-center md:justify-between md:mt-0"
      >
        <span
          >2026 Nexora Digitals. All rights reserved by Satyam Bhagat.</span
        >&nbsp
        <span>
          Developer contact:
          <a class="underline" href="https://github.com/satyam2006-cmd" target="_blank" rel="noopener noreferrer">github.com/satyam2006-cmd</a>
        </span>
      </div>
    </div>
  </div>
</section>
